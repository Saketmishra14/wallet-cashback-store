{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "handleMiss": true,
  "cleanUrls": false,
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "env_": {
    "VITE_API_URL": {
      "required": true
    }
  }
}
